  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts,js,json --exec tsx src/index.ts",
    "runScripts": "tsx src/script.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:seed": "NODE_ENV=development tsx prisma/seed.ts",
    "db:seed:test-prod-block": "cross-env NODE_ENV=production npm run db:seed",
    "db:generate": "prisma generate",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:studio:mongo": "open http://localhost:8081",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "generate-openapi": "tsx scripts/generate-openapi.ts"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/bcrypt": "^6.0.0",
    "@types/mongodb": "^4.0.6",
