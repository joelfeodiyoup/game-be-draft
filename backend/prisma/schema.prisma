// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id            String    @id @default(uuid()) @db.Uuid
  username      String    @unique @db.VarChar(50)
  // email String @unique @db.VarChar(255)
  password_hash String    @db.Char(60) // bcrypt hash is exactly 60 chars
  created_at    DateTime  @default(now()) @db.Timestamptz
  updated_at    DateTime  @updatedAt @db.Timestamptz
  game_saves    GameSave[]
  session       Session[]
  ratings       Rating[]
}

model GameSave {
  id                     String   @id @default(uuid()) @db.Uuid
  player_id              String   @db.Uuid
  player                 Player   @relation(fields: [player_id], references: [id], onDelete: Cascade)
  /// this references an index in the mongodb table holding the game state
  mongodb_state_id       String   @db.Char(24) // MongoDB ObjectId hex string is 24 chars
  time_played_in_seconds Int      @db.Integer // ~68 years max at 4 bytes
  created_at             DateTime @default(now()) @db.Timestamptz
  updated_at             DateTime @updatedAt @db.Timestamptz

  @@index([player_id])
  @@index([created_at])
}

model Scenario {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(200)
  description String   @db.Text // unlimited length for detailed descriptions
  created_at  DateTime @default(now()) @db.Timestamptz
  ratings     Rating[]
}

model Rating {
  player_id   String   @db.Uuid
  player      Player   @relation(fields: [player_id], references: [id], onDelete: Cascade)
  scenario_id String   @db.Uuid
  scenario    Scenario @relation(fields: [scenario_id], references: [id], onDelete: Cascade)
  rating      Int      @db.SmallInt // 2 bytes, range -32768 to 32767
  created_at  DateTime @default(now()) @db.Timestamptz

  @@id([player_id, scenario_id])
  @@index([scenario_id])
}

model Session {
  id         String   @id @default(uuid()) @db.Uuid
  player_id  String   @db.Uuid
  player     Player   @relation(fields: [player_id], references: [id], onDelete: Cascade)
  expires_at DateTime @db.Timestamptz
  created_at DateTime @default(now()) @db.Timestamptz

  @@index([player_id, expires_at])
}