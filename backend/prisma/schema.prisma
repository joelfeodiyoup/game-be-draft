// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator erd {
  provider = "prisma-erd-generator"
}

model Player {
  id            String    @id @default(uuid()) @db.Uuid
  username      String    @unique @db.VarChar(50)
  // email String @unique @db.VarChar(255)
  password_hash String    @db.Char(60) // bcrypt hash is exactly 60 chars
  created_at    DateTime  @default(now()) @db.Timestamptz
  updated_at    DateTime  @updatedAt @db.Timestamptz
  saves    ScenarioSave[]
  auth_session       AuthSession[]
  game_ratings       GameRating[]
  scenarioProgress PlayerProgress[]

  game_sessions GameSession[]

  auth_roles AuthRole[]
}

model AuthRole {
  role String @db.VarChar(5)

  player_id String @db.Uuid
  player Player @relation(fields: [player_id], references: [id], onDelete: Cascade)

  @@id([player_id, role])
  @@index([player_id])

  // I don't think I really need to search for all admins. But... maybe...
  // @@index([role])

}

model Game {
  id String @id @default(uuid()) @db.Uuid
  title String @db.VarChar(200)
  description String @db.Text
  scenarios Scenario[]
  created_at DateTime @default(now()) @db.Timestamptz

  // cached rating aggregates
  average_rating Decimal? @db.Decimal(3,2) // e.g., 4.25 (range 0.00-9.99)
  rating_count Int @default(0) @db.Integer

  game_sessions GameSession[]
  game_ratings GameRating[]
}

model GameSession {
  id String @id @default(uuid()) @db.Uuid
  created_at DateTime @default (now()) @db.Timestamptz
  end_time DateTime?

  game_id String @db.Uuid
  game Game @relation(fields: [game_id], references: [id], onDelete: Cascade)

  player_id String @db.Uuid
  player Player @relation(fields: [player_id], references: [id], onDelete: Cascade)

  @@index([player_id])
  @@index([game_id])
  @@index([created_at, game_id])
  @@index([end_time])
}

model ScenarioSave {
  id                     String   @id @default(uuid()) @db.Uuid
  player_id              String   @db.Uuid
  player                 Player   @relation(fields: [player_id], references: [id], onDelete: Cascade)
  /// this references an index in the mongodb table holding the game state
  mongodb_state_id       String   @db.Char(24) // MongoDB ObjectId hex string is 24 chars
  time_played_in_seconds Int      @db.Integer // ~68 years max at 4 bytes
  created_at             DateTime @default(now()) @db.Timestamptz
  updated_at             DateTime @updatedAt @db.Timestamptz

  scenario_id String @db.Uuid
  scenario Scenario @relation(fields: [scenario_id], references: [id], onDelete: Cascade)

  @@index([player_id])
  @@index([created_at])
}

model Scenario {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(200)
  description String   @db.Text // unlimited length for detailed descriptions
  created_at  DateTime @default(now()) @db.Timestamptz
  saves ScenarioSave[]

  /// this references an index in the mongodb table holding the scenario state
  mongo_state_id String @db.Char(24)

  game_id String @db.Uuid
  game Game @relation(fields: [game_id], references: [id], onDelete: Cascade)

  playerProgress PlayerProgress[]
}

model PlayerProgress {
  player_id String @db.Uuid
  player Player @relation(fields: [player_id], references: [id], onDelete: Cascade)

  scenario_id String @db.Uuid
  scenario Scenario @relation(fields: [scenario_id], references: [id], onDelete: Cascade)
  completed Boolean

  @@id([player_id, scenario_id])
}

model GameRating {
  player_id   String   @db.Uuid
  player      Player   @relation(fields: [player_id], references: [id], onDelete: Cascade)
  game_id String   @db.Uuid
  game    Game @relation(fields: [game_id], references: [id], onDelete: Cascade)
  rating      Int      @db.SmallInt // 2 bytes, range -32768 to 32767
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime  @updatedAt @db.Timestamptz
  comment String? @db.VarChar(2000)

  @@id([player_id, game_id])
  @@index([game_id])
}

model AuthSession {
  id         String   @id @default(uuid()) @db.Uuid
  player_id  String   @db.Uuid
  player     Player   @relation(fields: [player_id], references: [id], onDelete: Cascade)
  expires_at DateTime @db.Timestamptz
  created_at DateTime @default(now()) @db.Timestamptz

  @@index([player_id, expires_at])
}